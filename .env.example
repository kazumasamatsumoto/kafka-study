# Application
PORT=3000

# Environment
NODE_ENV=development

# Kafka Configuration (Local / AWS MSK共通)
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=nestjs-kafka-app
KAFKA_CONSUMER_GROUP_ID=nestjs-consumer-group

# AWS MSK用設定（本番環境のみ）
# NODE_ENV=production
# KAFKA_BROKERS=b-1.msk-cluster.xxxxx.kafka.ap-northeast-1.amazonaws.com:9092,b-2.msk-cluster.xxxxx.kafka.ap-northeast-1.amazonaws.com:9092,b-3.msk-cluster.xxxxx.kafka.ap-northeast-1.amazonaws.com:9092
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/MyKafkaRole
